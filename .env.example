# ============================================================
# CONFIGURACIÓN DE BASE DE DATOS (SUPABASE)
# ============================================================
# URL de conexión de Supabase (Usa el "Session Pooler" IPv4)
# postgresql+asyncpg://postgres.[USER]:[PASSWORD]@[HOST]:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://user:password@host:5432/postgres

# Configuración del pool (opcional, valores por defecto mostrados)
SUPABASE_POOL_SIZE=5
SUPABASE_MAX_OVERFLOW=10
SUPABASE_POOL_RECYCLE=1800
SUPABASE_POOL_TIMEOUT=30
SUPABASE_ECHO=false

# ============================================================
# CONFIGURACIÓN DE STORAGE (SUPABASE)
# ============================================================
# URL del proyecto Supabase (ej: https://xyz.supabase.co)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Service Role Key o Anon Key (Anon key es suficiente si las políticas son públicas)
SUPABASE_KEY=tu-api-key-aqui
